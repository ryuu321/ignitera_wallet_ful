generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  anonymousName     String    @unique
  realName          String?   
  role              String    @default("PLAYER")
  rank              String    @default("E")      // E, D, C, B, A, S
  skillLevel        Float     @default(1.0)
  skills            String    
  balanceFlow       Float     @default(1000)
  balanceStock      Float     @default(0)
  evaluationScore   Float     @default(0)
  tasksRequested    Task[]    @relation("RequestedBy")
  tasksAssigned     Task[]    @relation("AssignedTo")
  bids              Bid[]
  transactionsSent  Transaction[] @relation("FromUser")
  transactionsRecv  Transaction[] @relation("ToUser")
  messages          TaskMessage[]
  kpiLogs           KPILog[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Task {
  id                String    @id @default(uuid())
  title             String
  description       String
  requesterId       String
  requester         User      @relation("RequestedBy", fields: [requesterId], references: [id])
  assigneeId        String?
  assignee          User?     @relation("AssignedTo", fields: [assigneeId], references: [id])
  baseReward        Float     
  finalReward       Float?    
  status            String    @default("OPEN")
  position          String    @default("GENERAL") // MANAGER, SUB_MANAGER, SPECIALIST, GENERAL
  tags              String    @default("[]") // JSON string of tags
  expectedHours     Float     @default(1.0)
  
  // Complexity Factors (#11)
  requiredSkill     Float     @default(1.0)    // s_req
  outputs           Int       @default(1)      // n_o
  branches          Int       @default(0)      // n_b
  skillCount        Int       @default(1)      // n_s
  externalCount     Int       @default(0)      // n_e
  qualityScore      Float?
  bids              Bid[]
  messages          TaskMessage[]
  transaction       Transaction?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Bid {
  id                String    @id @default(uuid())
  taskId            String
  task              Task      @relation(fields: [taskId], references: [id])
  bidderId          String
  bidder            User      @relation(fields: [bidderId], references: [id])
  amount            Float     
  message           String?
  status            String    @default("PENDING")
  createdAt         DateTime  @default(now())
}

model TaskMessage {
  id                String    @id @default(uuid())
  taskId            String
  task              Task      @relation(fields: [taskId], references: [id])
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  content           String
  createdAt         DateTime  @default(now())
}

model Transaction {
  id                String    @id @default(uuid())
  taskId            String?   @unique
  task              Task?     @relation(fields: [taskId], references: [id])
  fromUserId        String
  fromUser          User      @relation("FromUser", fields: [fromUserId], references: [id])
  toUserId          String
  toUser            User      @relation("ToUser", fields: [toUserId], references: [id])
  amount            Float               // Base Coin (C)
  type              String    @default("PAYMENT") 
  
  // Reward Factors
  wu                Float     @default(1.0)
  wd                Float     @default(1.0)
  pc                Float     @default(1.0)
  q                 Float     @default(1.0)
  aa                Float     @default(1.0)
  rc                Float     @default(1.0)
  eb                Float     @default(0.0)
  ac                Float     @default(1.0)
  
  // Execution Data (#12)
  actualHours       Float     @default(1.0)
  rating            Float     @default(1.0)
  difficulty        Float     @default(1.0)    // D
  redistributionCost Float    @default(0.0)
  
  finalScore        Float     @default(0.0)    // S
  timestamp         DateTime  @default(now())
}

model KPILog {
  id                String    @id @default(uuid())
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  metricName        String    
  value             Float
  timestamp         DateTime  @default(now())
}

model SkillMaster {
  id                String    @id @default(uuid())
  name      String   @unique
  category  String   @default("General")
  createdAt DateTime @default(now())
}
