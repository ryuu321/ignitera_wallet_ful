generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  anonymousName     String    @unique
  role              String    @default("PLAYER")
  
  // Competitive Rank (A-Z)
  rank              String    @default("Z")
  monthlyScore      Float     @default(0.0)
  totalScore        Float     @default(0.0)
  lastMonthScore    Float     @default(0.0)
  graceMonths       Int       @default(0)
  skillLevel        Float     @default(1.0)
  skills            String    @default("[]") // RESTORED for project-specific skill tags
  
  balanceFlow       Float     @default(1000)
  balanceStock      Float     @default(0)
  balanceIgn        Float     @default(0)
  
  // Relationships
  tasksRequested    Task[]    @relation("RequestedBy")
  tasksAssigned     Task[]    @relation("AssignedTo")
  bids              Bid[]
  transactionsSent  Transaction[] @relation("FromUser")
  transactionsRecv  Transaction[] @relation("ToUser")
  messages          TaskMessage[]
  rankHistory       RankHistory[]
  expenses          Expense[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Expense {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  type              String    // TOOL, OUTSOURCING, LEARNING, EXPERIMENT
  amount            Float
  description       String?
  timestamp         DateTime  @default(now())
}


model Task {
  id                String    @id @default(uuid())
  title             String
  description       String
  status            String    @default("OPEN")
  
  baseReward        Float
  finalReward       Float     @default(0.0)
  expectedHours     Float     @default(1.0)
  outputs           Int       @default(1)
  branches          Int       @default(0)
  skillCount        Int       @default(1)
  externalCount     Int       @default(0)
  requiredSkill     Float     @default(1.0)
  
  position          String    @default("GENERAL")
  tags              String    @default("[]")
  
  requesterId       String
  requester         User      @relation("RequestedBy", fields: [requesterId], references: [id])
  assigneeId        String?
  assignee          User?     @relation("AssignedTo", fields: [assigneeId], references: [id])
  
  bids              Bid[]
  messages          TaskMessage[]
  transaction       Transaction?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Bid {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  bidderId    String
  bidder      User     @relation(fields: [bidderId], references: [id])
  amount      Float
  message     String   @default("")
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model TaskMessage {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String
  createdAt   DateTime @default(now())
}

model Transaction {
  id                String    @id @default(uuid())
  taskId            String?   @unique
  task              Task?     @relation(fields: [taskId], references: [id])
  fromUserId        String
  fromUser          User      @relation("FromUser", fields: [fromUserId], references: [id])
  toUserId          String
  toUser            User      @relation("ToUser", fields: [toUserId], references: [id])
  
  type              String    @default("PAYMENT")
  amount            Float
  finalScore        Float     @default(0.0)

  wu                Float     @default(1.0)
  wd                Float     @default(1.0)
  pc                Float     @default(1.0)
  q                 Float     @default(1.0)
  ac                Float     @default(1.0)
  aa                Float     @default(1.0)
  df                Float     @default(1.0)
  sf                Float     @default(1.0)
  eb                Float     @default(1.0)
  rr                Float     @default(1.0)
  
  // Raw Inputs for Audit
  rawExpectedHours  Float?
  rawActualHours    Float?
  rawOutputs        Int?
  rawBranches       Int?
  rawSkillCount     Int?
  rawRequiredSkill  Float?
  rawFrequency      Int?
  rawMaxShare       Float?
  
  timestamp         DateTime  @default(now())
}

model RankHistory {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  seasonId          String
  rank              String
  score             Float
  createdAt         DateTime  @default(now())
}

model KPILog {
  id          String   @id @default(uuid())
  metricName  String?
  value       Float?
  timestamp   DateTime @default(now())
}

model SkillMaster {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String
  createdAt   DateTime @default(now())
}
