generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  anonymousName     String    @unique
  role              String    @default("PLAYER")
  
  // Competitive Rank (A-Z)
  rank              String    @default("Z")
  monthlyScore      Float     @default(0.0)
  totalScore        Float     @default(0.0)
  lastMonthScore    Float     @default(0.0)
  graceMonths       Int       @default(0)
  skillLevel        Float     @default(1.0)
  
  balanceFlow       Float     @default(1000)
  balanceStock      Float     @default(0)
  
  // Relationships
  tasksRequested    Task[]    @relation("RequestedBy")
  tasksAssigned     Task[]    @relation("AssignedTo")
  bids              Bid[]
  transactionsSent  Transaction[] @relation("FromUser")
  transactionsRecv  Transaction[] @relation("ToUser")
  messages          TaskMessage[]
  rankHistory       RankHistory[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Task {
  id                String    @id @default(uuid())
  title             String
  description       String
  status            String    @default("OPEN")
  
  baseReward        Float
  expectedHours     Float
  outputs           Int       @default(1)
  branches          Int       @default(0)
  skillCount        Int       @default(1)
  externalCount     Int       @default(0)
  requiredSkill     Float     @default(1.0)
  
  position          String    @default("GENERAL")
  tags              String    @default("[]")
  
  requesterId       String
  requester         User      @relation("RequestedBy", fields: [requesterId], references: [id])
  assigneeId        String?
  assignee          User?     @relation("AssignedTo", fields: [assigneeId], references: [id])
  
  bids              Bid[]
  messages          TaskMessage[]
  transaction       Transaction?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Bid {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Float
  message     String   @default("")
  createdAt   DateTime @default(now())
}

model TaskMessage {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  content     String
  timestamp   DateTime @default(now())
}

model Transaction {
  id                String    @id @default(uuid())
  taskId            String?   @unique
  task              Task?     @relation(fields: [taskId], references: [id])
  fromUserId        String
  fromUser          User      @relation("FromUser", fields: [fromUserId], references: [id])
  toUserId          String
  toUser            User      @relation("ToUser", fields: [toUserId], references: [id])
  
  amount            Float
  finalScore        Float

  wu                Float
  wd                Float
  pc                Float
  q                 Float
  ac                Float
  aa                Float
  df                Float
  sf                Float
  eb                Float
  rr                Float
  
  timestamp         DateTime  @default(now())
}

model RankHistory {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  seasonId          String
  rank              String
  score             Float
  createdAt         DateTime  @default(now())
}

model KPILog {
  id                String    @id @default(uuid())
  totalTransactions Int       @default(0)
  avgQuality        Float     @default(0.0)
  totalAmount       Float     @default(0.0)
  timestamp         DateTime  @default(now())
}

model SkillMaster {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String
  createdAt   DateTime @default(now())
}
